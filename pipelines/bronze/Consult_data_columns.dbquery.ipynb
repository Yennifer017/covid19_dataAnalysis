   "source": [
    "SELECT \n",
    "    table_name AS `dataset`,\n",
    "    column_name AS `column`,\n",
    "    data_type AS `type`,\n",
    "    comment AS `description`\n",
    "FROM \n",
    "    system.information_schema.columns\n",
    "WHERE \n",
    "    table_catalog = 'covid19'  \n",
    "    AND table_schema = 'bronze' \n",
    "ORDER BY \n",
    "    table_name, \n",
    "    ordinal_position;"
   ]
  }
